---
layout: layout
---

<div class="post-preview-container" style="min-height: <%- config.per_page * 72 %>px">
    <% page.posts.each(function(post){ %>
    <div class="post-preview">
        <div class="post-time"><%= post.date.format(config.date_format) %></div>
        <div class="post-info">
            <a href="<%- full_url_for(post.path) %>">
                <h3>
                    <%- (post.title || "Untitled").replace(/[<>&"]/g,function(c){
                        return {'<':'&lt;','>':'&gt;','&':'&amp;','"':'&quot;'}[c];
                    }) %>
                </h3>
            </a>
            <p>
                <% if (post.tags.length){ %>
                <span>/</span>
                <% post.tags.forEach(function(tag){ %>
                <a class="tag" href="<%= config.root %>tags/#<%= tag.name %>" title="<%= tag.name %>"><%= tag.name %></a>
                <span>/</span>
                <% }) %>
                <% } %>
            </p>
        </div>
    </div>
    <% }); %>
</div>
<div class="pagination-bar">
    <div class="pagination-nav">
        <% if (page.prev) { %>
        <a class="pag-btn" href="<%- config.root %>" title="First">&laquo;&laquo;</a>
        <a class="pag-btn" href="<%- config.root %><%- page.prev_link %>" title="Previous">&laquo;</a>
        <% } else { %>
        <span class="pag-btn disabled">&laquo;&laquo;</span>
        <span class="pag-btn disabled">&laquo;</span>
        <% } %>

        <span class="pag-nums">
            <% var startP = Math.max(1, page.current - 2); %>
            <% var endP = Math.min(page.total, page.current + 2); %>
            <% if (startP > 1) { %>
                <a class="pag-num" href="<%- config.root %>">1</a>
                <% if (startP > 2) { %><span class="pag-dots">...</span><% } %>
            <% } %>
            <% for (var p = startP; p <= endP; p++) { %>
                <% if (p === page.current) { %>
                    <span class="pag-num current"><%= p %></span>
                <% } else { %>
                    <a class="pag-num" href="<%- config.root %><%- p === 1 ? '' : 'page/' + p + '/' %>"><%= p %></a>
                <% } %>
            <% } %>
            <% if (endP < page.total) { %>
                <% if (endP < page.total - 1) { %><span class="pag-dots">...</span><% } %>
                <a class="pag-num" href="<%- config.root %>page/<%= page.total %>/"><%= page.total %></a>
            <% } %>
        </span>

        <% if (page.next) { %>
        <a class="pag-btn" href="<%- config.root %><%- page.next_link %>" title="Next">&raquo;</a>
        <a class="pag-btn" href="<%- config.root %>page/<%= page.total %>/" title="Last">&raquo;&raquo;</a>
        <% } else { %>
        <span class="pag-btn disabled">&raquo;</span>
        <span class="pag-btn disabled">&raquo;&raquo;</span>
        <% } %>
    </div>
    <div class="pagination-jump">
        <span>Jump to</span>
        <input type="number" id="pag-jump-input" min="1" max="<%= page.total %>" value="<%= page.current %>" />
        <span class="pag-total">/ <%= page.total %></span>
        <button id="pag-jump-btn">GO</button>
    </div>
</div>
<script>
(function(){
    var btn = document.getElementById('pag-jump-btn');
    var inp = document.getElementById('pag-jump-input');
    function go(){
        var p = parseInt(inp.value, 10);
        if (p >= 1 && p <= <%= page.total %>) {
            window.location.href = '<%- config.root %>' + (p === 1 ? '' : 'page/' + p + '/');
        }
    }
    btn.addEventListener('click', go);
    inp.addEventListener('keydown', function(e){ if (e.key === 'Enter') go(); });
})();
</script>
